---
import { type Lang, useTranslations } from "../../i18n/landing";

const { lang = "en" }: { lang?: Lang } = Astro.props;
const t = useTranslations(lang);

// agents.yml example — code snippet showing custom team definition directly
// biome-ignore lint/correctness/noUnusedVariables: used in Astro template
const yamlSnippet = `agents:
  pm:
    name: Project Manager
    emoji: "📋"
    tools: [create_task, get_all_tasks, send_message, get_messages]
    systemPrompt: |
      You are the project manager.
      Break down requirements into tasks.
  fe:
    name: Frontend Engineer
    emoji: "💻"
    tools: [claim_task, get_my_tasks, post_artifact, send_message]
    systemPrompt: |
      You are a frontend engineer.
      Build React components, request reviews.`;

// Example team setup — based on agents.example.yml, noting these are not fixed roles
// biome-ignore lint/correctness/noUnusedVariables: used in Astro template
const exampleAgents = [
  { id: "pm", label: "PM", color: "#C17F24" },
  { id: "designer", label: "Designer", color: "#A0522D" },
  { id: "da", label: "DA", color: "#6B8E23" },
  { id: "fe", label: "FE", color: "#4682B4" },
  { id: "be", label: "BE", color: "#2E8B57" },
  { id: "qa", label: "QA", color: "#8B6914" },
  { id: "deployer", label: "Deployer", color: "#607080" },
];
---

<section class="roster">
  <div class="roster__header">
    <span class="roster__label" aria-hidden="true">{t("roster.label")}</span>
    <h2 class="roster__title">{t("roster.title1")}<br />{t("roster.title2")}</h2>
    <p class="roster__subtitle">
      {t("roster.subtitle")}
    </p>
  </div>

  <div class="roster__body">
    <!-- agents.yml code snippet -->
    <div class="roster__yaml-pane">
      <div class="roster__yaml-bar" aria-hidden="true">
        <span class="roster__yaml-dot" style="background:#FF5F56"></span>
        <span class="roster__yaml-dot" style="background:#FFBD2E"></span>
        <span class="roster__yaml-dot" style="background:#27C93F"></span>
        <span class="roster__yaml-filename">agents.yml</span>
      </div>
      <pre class="roster__yaml-code" aria-label="Example agents.yml configuration"><code>{yamlSnippet}</code></pre>
    </div>

    <!-- Right: description + example badges -->
    <div class="roster__info">
      <p class="roster__info-lead">
        {t("roster.infoLead")}
      </p>

      <!-- Example badges — web-dev team from agents.example.yml -->
      <div class="roster__examples" aria-label="Example agents from agents.example.yml">
        <span class="roster__examples-label">{t("roster.examplesLabel")}</span>
        <div class="roster__chips">
          {exampleAgents.map((agent) => (
            <span class="roster__chip">
              <span
                class="roster__chip-dot"
                style={`background-color: ${agent.color}`}
                aria-hidden="true"
              />
              {agent.label}
            </span>
          ))}
        </div>
      </div>

      <p class="roster__domain-note">{t("roster.domainNote")}</p>

      <a
        href="https://github.com/custardcream98/relay/blob/main/agents.example.yml"
        class="roster__link"
        target="_blank"
        rel="noopener noreferrer"
      >
        {t("roster.browseLink")}
        <span aria-hidden="true">→</span>
      </a>
    </div>
  </div>
</section>

<style>
  .roster {
    border-top: 1px solid var(--color-border);
    background-color: var(--color-bg-surface);
  }

  /* Header */
  .roster__header {
    max-width: 1100px;
    margin: 0 auto;
    padding: 5rem clamp(1.25rem, 5vw, 2.5rem) 3.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .roster__label {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-accent);
    letter-spacing: 0.06em;
    font-weight: 500;
  }

  .roster__title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4.5vw, 3rem);
    font-weight: 400;
    color: var(--color-text-primary);
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin: 0;
  }

  .roster__subtitle {
    font-size: 1rem;
    color: var(--color-text-secondary);
    line-height: 1.7;
    max-width: 520px;
    margin: 0;
    font-weight: 300;
  }

  /* Body — 2-column layout */
  .roster__body {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 clamp(1.25rem, 5vw, 2.5rem) 5rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2.5rem;
    align-items: start;
  }

  /* YAML code panel */
  .roster__yaml-pane {
    border-radius: 0.75rem;
    border: 1px solid var(--color-border-strong);
    background-color: var(--color-bg-root);
    overflow: hidden;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.07);
  }

  .roster__yaml-bar {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.625rem 0.875rem;
    border-bottom: 1px solid var(--color-border);
    background-color: var(--color-bg-surface);
  }

  .roster__yaml-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    opacity: 0.85;
  }

  .roster__yaml-filename {
    flex: 1;
    text-align: center;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--color-text-muted);
    letter-spacing: 0.04em;
  }

  .roster__yaml-code {
    margin: 0;
    padding: 1.25rem 1.375rem;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
    line-height: 1.75;
    overflow-x: auto;
  }

  .roster__yaml-code code {
    font-family: inherit;
    background: none;
    border: none;
    padding: 0;
    white-space: pre;
  }

  /* Right info area */
  .roster__info {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    padding-top: 0.5rem;
  }

  .roster__info-lead {
    font-size: 0.9375rem;
    color: var(--color-text-primary);
    line-height: 1.75;
    margin: 0;
    font-weight: 300;
  }

  /* Example badge block */
  .roster__examples {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .roster__examples-label {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--color-text-secondary);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .roster__chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .roster__chip {
    display: inline-flex;
    align-items: center;
    gap: 0.4375rem;
    padding: 0.3125rem 0.75rem;
    border-radius: 9999px;
    border: 1px solid var(--color-border);
    background-color: var(--color-bg-raised);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-text-secondary);
    letter-spacing: 0.02em;
    transition: border-color 0.15s, color 0.15s;
  }

  .roster__chip:hover {
    border-color: var(--color-accent);
    color: var(--color-text-primary);
  }

  .roster__chip-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    flex-shrink: 0;
    opacity: 0.85;
  }

  /* Multi-domain note */
  .roster__domain-note {
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin: 0;
    font-weight: 300;
    font-style: italic;
  }

  /* Link */
  .roster__link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--color-accent);
    text-decoration: none;
    letter-spacing: 0.02em;
    transition: opacity 0.15s;
    width: fit-content;
  }

  .roster__link:hover {
    opacity: 0.75;
  }

  /* Responsive: single column on narrow screens */
  @media (max-width: 760px) {
    .roster__body {
      grid-template-columns: 1fr;
    }
  }
</style>
