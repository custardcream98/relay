{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "types": ["node", "bun"],
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "paths": {
      "relay-shared": ["./packages/shared/index.ts"]
    }
  },
  "include": ["packages/server/src/**/*", "packages/shared/**/*"]
}
