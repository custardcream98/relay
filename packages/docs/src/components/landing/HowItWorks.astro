---
import { type Lang, useTranslations } from "../../i18n/landing";

const { lang = "en" }: { lang?: Lang } = Astro.props;
const t = useTranslations(lang);

// biome-ignore lint/correctness/noUnusedVariables: used in Astro template
const steps = [
  {
    number: "01",
    title: t("how.step1.title"),
    description: t("how.step1.desc"),
    code: "claude mcp add --scope user relay -- npx -y --package @custardcream/relay relay",
  },
  {
    number: "02",
    title: t("how.step2.title"),
    description: t("how.step2.desc"),
    code: "/relay:init",
  },
  {
    number: "03",
    title: t("how.step3.title"),
    description: t("how.step3.desc"),
    code: '/relay:relay "add dark mode toggle"',
  },
];
---

<section class="how">
  <!-- Section header -->
  <div class="how__header">
    <div class="how__header-inner">
      <span class="how__label" aria-hidden="true">{t("how.label")}</span>
      <h2 class="how__title">{t("how.title1")}<br />{t("how.title2")}</h2>
      <p class="how__subtitle">
        {t("how.subtitle")}
      </p>
    </div>
  </div>

  <!-- Step list — editorial layout divided by horizontal rules -->
  <div class="how__steps">
    {
      steps.map((step, i) => (
        <div class="how__step" style={`animation-delay: ${i * 0.1}s`}>
          <div class="how__step-num-col" aria-hidden="true">
            <span class="how__step-num">{step.number}</span>
          </div>
          <div class="how__step-content">
            <h3 class="how__step-title">{step.title}</h3>
            <p class="how__step-desc">{step.description}</p>
          </div>
          <div class="how__step-code-col">
            <code class="how__step-code">{step.code}</code>
          </div>
        </div>
      ))
    }
  </div>
</section>

<style>
  .how {
    border-top: 1px solid var(--color-border);
  }

  /* Header area */
  .how__header {
    background-color: var(--color-bg-surface);
    padding: 5rem 0 4.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  .how__header-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 clamp(1.25rem, 5vw, 2.5rem);
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .how__label {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-accent);
    letter-spacing: 0.06em;
    font-weight: 500;
  }

  .how__title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4.5vw, 3rem);
    font-weight: 400;
    color: var(--color-text-primary);
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin: 0;
    max-width: 560px;
  }

  .how__subtitle {
    font-size: 1rem;
    color: var(--color-text-secondary);
    line-height: 1.7;
    max-width: 480px;
    margin: 0;
    font-weight: 300;
  }

  /* Step list — editorial horizontal layout */
  .how__steps {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 clamp(1.25rem, 5vw, 2.5rem);
    overflow: hidden;
  }

  @keyframes step-in {
    from { opacity: 0; transform: translateY(12px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .how__step {
    display: grid;
    grid-template-columns: 4rem 1fr auto;
    align-items: center;
    gap: 2rem;
    padding: 2.25rem 0.75rem;
    border-bottom: 1px solid var(--color-border);
    animation: step-in 0.4s ease-out both;
    border-radius: 0.5rem;
    transition: background-color 0.18s, border-bottom-color 0.18s;
  }

  .how__step:last-child {
    border-bottom: none;
  }

  .how__step:hover {
    background-color: var(--color-accent-glow);
    border-bottom-color: transparent;
  }

  .how__step:hover + .how__step {
    border-top-color: transparent;
  }

  /* Number column */
  .how__step-num-col {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .how__step-num {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-accent);
    letter-spacing: 0.1em;
    opacity: 0.8;
  }

  /* Content column */
  .how__step-content {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .how__step-title {
    font-family: var(--font-display);
    font-size: 1.375rem;
    font-weight: 400;
    color: var(--color-text-primary);
    letter-spacing: -0.02em;
    margin: 0;
  }

  .how__step-desc {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.65;
    margin: 0;
    font-weight: 300;
    max-width: 440px;
  }

  /* Code column */
  .how__step-code-col {
    flex-shrink: 0;
    max-width: 320px;
  }

  .how__step-code {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
    background-color: var(--color-bg-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.375rem;
    padding: 0.5rem 0.875rem;
    word-break: break-all;
    line-height: 1.6;
    transition: border-color 0.18s, color 0.18s;
  }

  .how__step:hover .how__step-code {
    border-color: var(--color-accent);
    color: var(--color-text-primary);
  }

  /* Responsive */
  @media (max-width: 700px) {
    .how__step {
      grid-template-columns: 2.5rem 1fr;
      grid-template-rows: auto auto;
    }

    .how__step-code-col {
      grid-column: 2;
      max-width: 100%;
    }
  }
</style>
