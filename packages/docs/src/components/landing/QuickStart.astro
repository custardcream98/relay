---
// biome-ignore lint/correctness/noUnusedVariables: used in Astro template
const snippets = [
  {
    label: "1. Install",
    code: `claude mcp add --npm @custardcream/relay relay-server`,
  },
  {
    label: "2. Initialise memory",
    code: `/relay:init`,
  },
  {
    label: "3. Ship a feature",
    code: `/relay:relay "add OAuth login with Google"`,
  },
];
---

<section class="qs">
  <div class="qs__inner">
    <h2 class="qs__title">Quick start</h2>
    <p class="qs__subtitle">
      Up and running in under two minutes.
    </p>
    <div class="qs__snippets">
      {
        snippets.map((snippet) => (
          <div class="qs__block">
            <p class="qs__label">{snippet.label}</p>
            <pre class="qs__pre"><code>{snippet.code}</code></pre>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .qs {
    background-color: var(--color-bg-surface);
    padding: 5rem 0;
  }

  .qs__inner {
    max-width: 960px;
    margin: 0 auto;
    padding: 0 clamp(1rem, 5vw, 2rem);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3rem;
  }

  .qs__title {
    font-size: clamp(1.75rem, 4vw, 2.25rem);
    font-weight: 700;
    color: var(--color-text-primary);
    letter-spacing: -0.02em;
    margin: 0;
    text-align: center;
  }

  .qs__subtitle {
    font-size: 1rem;
    color: var(--color-text-secondary);
    text-align: center;
    margin: -2rem 0 0;
    line-height: 1.7;
  }

  .qs__snippets {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    width: 100%;
    max-width: 720px;
  }

  .qs__block {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .qs__label {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-text-muted);
    margin: 0;
    letter-spacing: 0.02em;
  }

  .qs__pre {
    margin: 0;
    padding: 0.875rem 1.125rem;
    background-color: var(--color-bg-root);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    overflow-x: auto;
  }

  .qs__pre code {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    color: var(--color-text-primary);
    white-space: pre;
  }
</style>
