---
// Landing page layout — bypasses Starlight to apply custom Nav, design tokens, and styles
// biome-ignore lint/correctness/noUnusedImports: used in Astro template
import Nav from "../components/landing/Nav.astro";
import type { Lang } from "../i18n/landing";

interface Props {
  lang?: Lang;
  title?: string;
  description?: string;
}

const { lang = "en" } = Astro.props;
// biome-ignore lint/correctness/noUnusedVariables: used in Astro template
const title = Astro.props.title ?? "relay — Multi-agent framework for Claude Code";
// biome-ignore lint/correctness/noUnusedVariables: used in Astro template
const description =
  Astro.props.description ??
  (lang === "ko-KR"
    ? "YAML 파일 하나로 Claude 에이전트 팀을 구성하세요. P2P 협업, 이벤트 기반, 추가 요금 없음. Claude Code 전용 멀티 에이전트 프레임워크."
    : "relay gives you a collaborating team of Claude agents — peer-to-peer, event-driven, no orchestrator code. Pick any team from the pool. No new API keys. No extra billing.");

const BASE = "https://custardcream98.github.io/relay";
// biome-ignore lint/correctness/noUnusedVariables: used in Astro template
const canonicalUrl = lang === "ko-KR" ? `${BASE}/ko-KR/` : `${BASE}/`;
// biome-ignore lint/correctness/noUnusedVariables: used in Astro template
const ogImageUrl = `${BASE}/og.svg`;
// biome-ignore lint/correctness/noUnusedVariables: used in Astro template
const ogLocale = lang === "ko-KR" ? "ko_KR" : "en_US";

// biome-ignore lint/correctness/noUnusedVariables: used in Astro template
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "relay",
  description:
    "A domain-agnostic multi-agent collaboration framework built on Claude Code. Pick any team from the pool and agents collaborate peer-to-peer via MCP tools.",
  url: `${BASE}/`,
  applicationCategory: "DeveloperApplication",
  operatingSystem: "macOS, Linux, Windows",
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
  codeRepository: "https://github.com/custardcream98/relay",
  programmingLanguage: "TypeScript",
  license: "https://opensource.org/licenses/MIT",
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta
      name="keywords"
      content="Claude Code, multi-agent, AI agents, MCP, workflow automation, relay, peer-to-peer agents, Claude"
    />
    <title>{title}</title>
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="en" href={`${BASE}/`} />
    <link rel="alternate" hreflang="ko" href={`${BASE}/ko-KR/`} />
    <link rel="alternate" hreflang="x-default" href={`${BASE}/`} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="relay" />
    <meta property="og:locale" content={ogLocale} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- JSON-LD structured data -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <link rel="icon" href={`${import.meta.env.BASE_URL}/favicon.svg`} type="image/svg+xml" />
    <!-- Distinctive font pairing: Berkeley Mono style + editorial serif -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Mono:ital,wght@0,300;0,400;0,500;1,400&family=DM+Serif+Display:ital@0;1&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&family=Noto+Serif+KR:wght@400;700&family=Noto+Sans+KR:wght@300;400;500&display=swap"
      rel="stylesheet"
    />
    <style>
      /* Tailwind v4 entry point */
      @import "tailwindcss";

      /* ─── Design tokens ─── */
      :root {
        /* Light mode — cream/off-white base, ink text */
        --color-bg-root:    #F5F0E8;
        --color-bg-surface: #EDE8DF;
        --color-bg-raised:  #FAF7F2;
        --color-text-primary:   #1A1410;
        --color-text-secondary: #5C5043;
        --color-text-muted:     #9A8E7E;
        --color-border:     #D4C9B8;
        --color-border-strong: #B8AA96;

        /* Amber/gold accent — warm golden tone instead of purple */
        --color-accent:       #C17F24;
        --color-accent-light: #E8A83A;
        --color-accent-glow:  rgba(193, 127, 36, 0.15);

        /* Agent colors — harmonious palette */
        --agent-pm:       #C17F24;
        --agent-designer: #A0522D;
        --agent-da:       #6B8E23;
        --agent-fe:       #4682B4;
        --agent-be:       #2E8B57;
        --agent-qa:       #8B4513;
        --agent-deployer: #708090;

        --font-display: "DM Serif Display", "Noto Serif KR", Georgia, serif;
        --font-sans:    "DM Sans", "Noto Sans KR", system-ui, sans-serif;
        --font-mono:    "DM Mono", "JetBrains Mono", "Fira Code", monospace;

        /* For noise texture overlay layer */
        --noise-opacity: 0.035;
      }

      @media (prefers-color-scheme: dark) {
        :root {
          /* Dark mode — deep ink base, warm cream text */
          --color-bg-root:    #0F0D0A;
          --color-bg-surface: #181410;
          --color-bg-raised:  #1E1A14;
          --color-text-primary:   #F0E8D8;
          --color-text-secondary: #A89880;
          --color-text-muted:     #6A5E50;
          --color-border:     #2A2318;
          --color-border-strong: #3D3428;

          --color-accent:       #E8A83A;
          --color-accent-light: #F5C860;
          --color-accent-glow:  rgba(232, 168, 58, 0.12);

          --noise-opacity: 0.06;
        }
      }

      /* ─── Base reset ─── */
      *,
      *::before,
      *::after {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      html,
      body {
        margin: 0;
        padding: 0;
        background-color: var(--color-bg-root);
        color: var(--color-text-primary);
        font-family: var(--font-sans);
        font-weight: 300;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }

      /* Subtle noise overlay — paper texture */
      body::before {
        content: "";
        position: fixed;
        inset: 0;
        pointer-events: none;
        z-index: 9998;
        opacity: var(--noise-opacity);
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
        background-size: 256px 256px;
      }

      img,
      svg {
        display: block;
      }

      /* Skip link */
      .skip-link {
        position: absolute;
        top: -100%;
        left: 1rem;
        padding: 0.5rem 1rem;
        background: var(--color-accent);
        color: var(--color-bg-root);
        font-size: 0.875rem;
        font-family: var(--font-mono);
        border-radius: 0 0 0.375rem 0.375rem;
        text-decoration: none;
        z-index: 9999;
      }
      .skip-link:focus {
        top: 0;
      }

      /* Page load fade-in */
      @keyframes page-in {
        from { opacity: 0; transform: translateY(6px); }
        to   { opacity: 1; transform: translateY(0); }
      }

      main {
        animation: page-in 0.5s ease-out both;
      }

      /* Korean typography adjustments */
      :lang(ko) h1,
      :lang(ko) h2,
      :lang(ko) h3,
      :lang(ko) p {
        word-break: keep-all;
        overflow-wrap: break-word;
      }
    </style>
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to content</a>
    <Nav lang={lang} />
    <main id="main-content">
      <slot />
    </main>
  </body>
</html>
