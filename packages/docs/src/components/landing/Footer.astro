---
const base = import.meta.env.BASE_URL;

// biome-ignore lint/correctness/noUnusedVariables: Astro 템플릿에서 사용
const links = [
  { label: "Docs", href: `${base}getting-started/introduction` },
  { label: "GitHub", href: "https://github.com/custardcream98/relay", external: true },
  { label: "npm", href: "https://www.npmjs.com/package/@custardcream/relay", external: true },
];
---

<footer class="footer">
  <div class="footer__inner">
    <!-- 왼쪽: 로고 + 설명 -->
    <div class="footer__brand">
      <span class="footer__wordmark">
        relay<span class="footer__wordmark-cursor" aria-hidden="true">_</span>
      </span>
      <p class="footer__tagline">
        Multi-agent framework for Claude Code.
      </p>
    </div>

    <!-- 가운데: 설치 명령 -->
    <div class="footer__install" aria-label="Install command">
      <span class="footer__install-label">install</span>
      <code class="footer__install-code">claude mcp add --npm @custardcream/relay relay-server</code>
    </div>

    <!-- 오른쪽: 링크 + 라이선스 -->
    <div class="footer__right">
      <nav class="footer__links" aria-label="Footer navigation">
        {
          links.map((link) => (
            <a
              href={link.href}
              class="footer__link"
              target={link.external ? "_blank" : undefined}
              rel={link.external ? "noopener noreferrer" : undefined}
            >
              {link.label}
            </a>
          ))
        }
      </nav>
      <p class="footer__copy">MIT &copy; {new Date().getFullYear()}</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--color-border);
    background-color: var(--color-bg-surface);
    padding: 3.5rem 0;
  }

  .footer__inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 clamp(1.25rem, 5vw, 2.5rem);
    display: grid;
    grid-template-columns: 1fr 1.5fr 1fr;
    align-items: center;
    gap: 2rem;
  }

  /* 브랜드 */
  .footer__brand {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer__wordmark {
    font-family: var(--font-mono);
    font-size: 1.0625rem;
    font-weight: 500;
    color: var(--color-text-primary);
    letter-spacing: -0.02em;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0; }
  }

  .footer__wordmark-cursor {
    color: var(--color-accent);
    animation: blink 1.1s step-end infinite;
  }

  .footer__tagline {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    margin: 0;
    font-weight: 300;
    line-height: 1.5;
  }

  /* 설치 명령 */
  .footer__install {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .footer__install-label {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    color: var(--color-text-muted);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .footer__install-code {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-text-secondary);
    background-color: var(--color-bg-root);
    border: 1px solid var(--color-border);
    border-radius: 0.375rem;
    padding: 0.5rem 0.75rem;
    word-break: break-all;
    line-height: 1.5;
    display: block;
  }

  /* 오른쪽 링크 + 카피 */
  .footer__right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.75rem;
  }

  .footer__links {
    display: flex;
    gap: 1.5rem;
    align-items: center;
  }

  .footer__link {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
    text-decoration: none;
    letter-spacing: 0.02em;
    transition: color 0.15s;
  }

  .footer__link:hover {
    color: var(--color-accent);
  }

  .footer__copy {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    margin: 0;
    font-family: var(--font-mono);
    letter-spacing: 0.02em;
  }

  /* 반응형 */
  @media (max-width: 800px) {
    .footer__inner {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .footer__right {
      align-items: flex-start;
    }
  }
</style>
