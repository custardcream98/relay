{
  "name": "relay",
  "version": "0.1.0",
  "description": "Multi-agent collaboration framework built on Claude Code",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/custardcream98/relay.git"
  },
  "homepage": "https://custardcream98.github.io/relay",
  "license": "MIT",
  "scripts": {
    "dev": "bun run --filter relay-server dev",
    "start": "bun run --filter relay-server start",
    "test": "bun run --filter relay-server test",
    "check": "eslint . && prettier --check .",
    "lint": "eslint .",
    "format": "prettier --write .",
    "dashboard:dev": "bun run --filter relay-dashboard dev",
    "dashboard:build": "bun run --filter relay-dashboard build",
    "docs:dev": "bun run --filter relay-docs dev",
    "docs:build": "bun run --filter relay-docs build",
    "build:server": "bun run --filter relay-server build",
    "build:release": "bun run dashboard:build && bun run build:server",
    "bump": "node scripts/sync-plugin-version.js",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@types/bun": "^1.3.10",
    "@types/node": "^25.5.0",
    "eslint": "^9.28.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-perfectionist": "^5.7.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "typescript-eslint": "^8.33.0"
  }
}
