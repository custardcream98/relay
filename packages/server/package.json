{
  "name": "@custardcream/relay",
  "version": "0.13.1",
  "description": "MCP server for the relay multi-agent framework",
  "type": "module",
  "bin": {
    "relay": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "RELAY_DASHBOARD_DIR=$(pwd)/../dashboard/dist bun run --watch src/index.ts",
    "start": "node dist/index.js",
    "build": "bun run build.ts",
    "test": "bun test",
    "version": "node ../../scripts/sync-plugin-version.js"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.4",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "hono": "^4.12.7",
    "js-yaml": "^4.1.1",
    "ws": "^8.18.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "1.3.10",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.15.29",
    "@types/ws": "^8.5.15",
    "esbuild": "^0.25.5"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/custardcream98/relay.git",
    "directory": "packages/server"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT"
}
