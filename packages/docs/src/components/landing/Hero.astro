---
const base = import.meta.env.BASE_URL;
// biome-ignore lint/correctness/noUnusedVariables: used in Astro template
const docsUrl = `${base}/getting-started/introduction`;
---

<section class="hero">
  <div class="hero__inner">
    <span class="hero__badge">Claude Code Plugin</span>
    <h1 class="hero__headline">
      Your codebase,<br />worked by a team.
    </h1>
    <p class="hero__subheadline">
      relay spins up a crew of AI agents — PM, Designer, FE, BE, QA, Deployer —
      that collaborate inside Claude Code to ship features end-to-end.
    </p>
    <div class="hero__cta">
      <a href={docsUrl} class="btn btn--primary">Get Started</a>
      <a
        href="https://github.com/custardcream98/relay"
        target="_blank"
        rel="noopener noreferrer"
        class="btn btn--secondary"
      >
        GitHub
      </a>
    </div>
    <p class="hero__install">
      <span class="hero__install-label">Quick install:</span>
      <code class="hero__install-code">claude mcp add --npm @custardcream/relay relay-server</code>
    </p>
  </div>
</section>

<style>
  .hero {
    padding-top: calc(56px + 5rem);
    padding-bottom: 5rem;
    text-align: center;
  }

  .hero__inner {
    max-width: 960px;
    margin: 0 auto;
    padding: 0 clamp(1rem, 5vw, 2rem);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  .hero__badge {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    border-radius: 9999px;
    border: 1px solid var(--color-accent);
    color: var(--color-accent);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .hero__headline {
    font-size: clamp(2.25rem, 6vw, 3.75rem);
    font-weight: 800;
    color: var(--color-text-primary);
    line-height: 1.1;
    letter-spacing: -0.03em;
    margin: 0;
  }

  .hero__subheadline {
    font-size: clamp(1rem, 2.5vw, 1.125rem);
    color: var(--color-text-secondary);
    line-height: 1.7;
    max-width: 560px;
    margin: 0;
  }

  .hero__cta {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    padding: 0.625rem 1.5rem;
    border-radius: 0.5rem;
    font-size: 0.9375rem;
    font-weight: 600;
    text-decoration: none;
    transition: opacity 0.15s, transform 0.1s;
  }

  .btn:hover {
    opacity: 0.88;
    transform: translateY(-1px);
  }

  .btn--primary {
    background-color: var(--color-accent);
    color: #fff;
  }

  .btn--secondary {
    background-color: transparent;
    color: var(--color-text-primary);
    border: 1px solid var(--color-border);
  }

  .hero__install {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    justify-content: center;
    color: var(--color-text-muted);
    font-size: 0.875rem;
    margin: 0;
  }

  .hero__install-label {
    font-weight: 500;
  }

  .hero__install-code {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    background-color: var(--color-bg-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.375rem;
    padding: 0.125rem 0.5rem;
    color: var(--color-text-secondary);
  }
</style>
