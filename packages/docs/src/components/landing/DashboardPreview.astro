---
import { type Lang, useTranslations } from "../../i18n/landing";

const { lang = "en" }: { lang?: Lang } = Astro.props;
const t = useTranslations(lang);
const screenshotSrc =
  lang === "ko-KR" ? "/relay/screenshots/dashboard-ko.png" : "/relay/screenshots/dashboard-en.png";
const screenshotAlt =
  lang === "ko-KR" ? "relay 대시보드 — 라이브 세션" : "relay dashboard — live session in progress";
---

<section class="dp">
  <!-- Section header -->
  <div class="dp__header">
    <span class="dp__label" aria-hidden="true">{t("dashboard.label")}</span>
    <h2 class="dp__title">
      {t("dashboard.title1")}<br />
      <em class="dp__title-em">{t("dashboard.title2")}</em>
    </h2>
    <p class="dp__subtitle">{t("dashboard.subtitle")}</p>
  </div>

  <!-- Browser chrome wrapper -->
  <div class="dp__browser">
    <!-- Browser title bar -->
    <div class="dp__browser-bar">
      <div class="dp__browser-dots" aria-hidden="true">
        <span class="dp__dot" style="background:#FF5F56"></span>
        <span class="dp__dot" style="background:#FFBD2E"></span>
        <span class="dp__dot" style="background:#27C93F"></span>
      </div>
      <!-- Tab -->
      <div class="dp__browser-tab" aria-hidden="true">
        <span class="dp__tab-icon">⚡</span>
        <span>relay</span>
      </div>
      <!-- URL bar -->
      <div class="dp__browser-url" aria-hidden="true">
        <span class="dp__url-dot"></span>
        localhost:3456 &mdash; relay dashboard
      </div>
    </div>

    <!-- Real dashboard screenshot -->
    <img
      src={screenshotSrc}
      alt={screenshotAlt}
      class="dp__screenshot"
      loading="lazy"
      decoding="async"
    />
  </div>
</section>

<style>
  /* ─── Section wrapper ─── */
  .dp {
    border-top: 1px solid var(--color-border);
    background-color: var(--color-bg-root);
    padding: 5rem 0 6rem;
  }

  /* ─── Section header ─── */
  .dp__header {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 clamp(1.25rem, 5vw, 2.5rem) 3.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .dp__label {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-accent);
    letter-spacing: 0.06em;
    font-weight: 500;
  }

  .dp__title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4.5vw, 3rem);
    font-weight: 400;
    color: var(--color-text-primary);
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin: 0;
  }

  .dp__title-em {
    font-style: italic;
    color: var(--color-accent);
  }

  .dp__subtitle {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.7;
    margin: 0;
    font-weight: 300;
    max-width: 480px;
  }

  /* ─── Browser chrome ─── */
  .dp__browser {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 clamp(1.25rem, 5vw, 2.5rem);
  }

  .dp__browser-bar {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.6rem 1rem;
    background-color: var(--color-bg-surface);
    border: 1px solid var(--color-border-strong);
    border-bottom: none;
    border-radius: 0.75rem 0.75rem 0 0;
  }

  .dp__browser-dots {
    display: flex;
    gap: 0.375rem;
    flex-shrink: 0;
  }

  .dp__dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    opacity: 0.85;
    display: inline-block;
  }

  .dp__browser-tab {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.25rem 0.75rem;
    background-color: var(--color-bg-raised);
    border: 1px solid var(--color-border);
    border-radius: 0.375rem;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--color-text-secondary);
    flex-shrink: 0;
  }

  .dp__tab-icon {
    font-size: 0.625rem;
  }

  .dp__browser-url {
    flex: 1;
    padding: 0.25rem 0.75rem;
    background-color: var(--color-bg-raised);
    border: 1px solid var(--color-border);
    border-radius: 0.375rem;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--color-text-muted);
    display: flex;
    align-items: center;
    gap: 0.5rem;
    min-width: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .dp__url-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #27C93F;
    flex-shrink: 0;
    opacity: 0.8;
  }

  /* ─── Real screenshot ─── */
  .dp__screenshot {
    display: block;
    width: 100%;
    border: 1px solid var(--color-border-strong);
    border-top: none;
    border-radius: 0 0 0.75rem 0.75rem;
  }

  /* ─── Responsive ─── */
  @media (max-width: 600px) {
    .dp__browser-tab {
      display: none;
    }
  }
</style>
