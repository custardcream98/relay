---
// Landing page 레이아웃 — Starlight를 우회해 커스텀 Nav, 디자인 토큰, 스타일 적용
// biome-ignore lint/correctness/noUnusedImports: Astro 템플릿에서 사용
import Nav from "../components/landing/Nav.astro";

interface Props {
  title?: string;
  description?: string;
}

// biome-ignore lint/correctness/noUnusedVariables: Astro 템플릿에서 사용
const title = Astro.props.title ?? "relay — Multi-agent framework for Claude Code";
// biome-ignore lint/correctness/noUnusedVariables: Astro 템플릿에서 사용
const description =
  Astro.props.description ??
  "relay spins up a crew of AI agents that collaborate inside Claude Code to ship features end-to-end.";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" href={`${import.meta.env.BASE_URL}favicon.svg`} type="image/svg+xml" />
    <!-- 개성 있는 폰트 조합: Berkeley Mono 스타일 + editorial serif -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Mono:ital,wght@0,300;0,400;0,500;1,400&family=DM+Serif+Display:ital@0;1&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&display=swap"
      rel="stylesheet"
    />
    <style>
      /* Tailwind v4 진입점 */
      @import "tailwindcss";

      /* ─── 디자인 토큰 ─── */
      :root {
        /* 라이트 모드 — 크림/오프화이트 베이스, 잉크 텍스트 */
        --color-bg-root:    #F5F0E8;
        --color-bg-surface: #EDE8DF;
        --color-bg-raised:  #FAF7F2;
        --color-text-primary:   #1A1410;
        --color-text-secondary: #5C5043;
        --color-text-muted:     #9A8E7E;
        --color-border:     #D4C9B8;
        --color-border-strong: #B8AA96;

        /* 앰버/골드 강조 — 보라 대신 따뜻한 황금빛 */
        --color-accent:       #C17F24;
        --color-accent-light: #E8A83A;
        --color-accent-glow:  rgba(193, 127, 36, 0.15);

        /* 에이전트 색상 — 조화로운 팔레트 */
        --agent-pm:       #C17F24;
        --agent-designer: #A0522D;
        --agent-da:       #6B8E23;
        --agent-fe:       #4682B4;
        --agent-be:       #2E8B57;
        --agent-qa:       #8B4513;
        --agent-deployer: #708090;

        --font-display: "DM Serif Display", Georgia, serif;
        --font-sans:    "DM Sans", system-ui, sans-serif;
        --font-mono:    "DM Mono", "JetBrains Mono", "Fira Code", monospace;

        /* 노이즈 텍스처 레이어용 */
        --noise-opacity: 0.035;
      }

      @media (prefers-color-scheme: dark) {
        :root {
          /* 다크 모드 — 딥 잉크 베이스, 웜 크림 텍스트 */
          --color-bg-root:    #0F0D0A;
          --color-bg-surface: #181410;
          --color-bg-raised:  #1E1A14;
          --color-text-primary:   #F0E8D8;
          --color-text-secondary: #A89880;
          --color-text-muted:     #6A5E50;
          --color-border:     #2A2318;
          --color-border-strong: #3D3428;

          --color-accent:       #E8A83A;
          --color-accent-light: #F5C860;
          --color-accent-glow:  rgba(232, 168, 58, 0.12);

          --noise-opacity: 0.06;
        }
      }

      /* ─── 기본 리셋 ─── */
      *,
      *::before,
      *::after {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      html,
      body {
        margin: 0;
        padding: 0;
        background-color: var(--color-bg-root);
        color: var(--color-text-primary);
        font-family: var(--font-sans);
        font-weight: 300;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }

      /* 미세 노이즈 오버레이 — 페이퍼 질감 */
      body::before {
        content: "";
        position: fixed;
        inset: 0;
        pointer-events: none;
        z-index: 9998;
        opacity: var(--noise-opacity);
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
        background-size: 256px 256px;
      }

      img,
      svg {
        display: block;
      }

      /* 스킵 링크 */
      .skip-link {
        position: absolute;
        top: -100%;
        left: 1rem;
        padding: 0.5rem 1rem;
        background: var(--color-accent);
        color: var(--color-bg-root);
        font-size: 0.875rem;
        font-family: var(--font-mono);
        border-radius: 0 0 0.375rem 0.375rem;
        text-decoration: none;
        z-index: 9999;
      }
      .skip-link:focus {
        top: 0;
      }

      /* 페이지 로드 페이드인 */
      @keyframes page-in {
        from { opacity: 0; transform: translateY(6px); }
        to   { opacity: 1; transform: translateY(0); }
      }

      main {
        animation: page-in 0.5s ease-out both;
      }
    </style>
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to content</a>
    <Nav />
    <main id="main-content">
      <slot />
    </main>
  </body>
</html>
