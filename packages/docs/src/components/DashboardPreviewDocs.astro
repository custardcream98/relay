---
// Standalone dashboard preview for MDX docs pages.
// No i18n dependency — strings are hardcoded in English.
---

<div class="dpd__browser" role="img" aria-label="relay dashboard mockup">
  <!-- Browser title bar -->
  <div class="dpd__browser-bar">
    <div class="dpd__browser-dots" aria-hidden="true">
      <span class="dpd__dot" style="background:#FF5F56"></span>
      <span class="dpd__dot" style="background:#FFBD2E"></span>
      <span class="dpd__dot" style="background:#27C93F"></span>
    </div>
    <div class="dpd__browser-tab" aria-hidden="true">
      <span class="dpd__tab-icon">⚡</span>
      <span>relay</span>
    </div>
    <div class="dpd__browser-url" aria-hidden="true">
      <span class="dpd__url-dot"></span>
      localhost:3456 &mdash; relay dashboard
    </div>
  </div>

  <!-- Dashboard body: 3-panel layout -->
  <div class="dpd__panels">

    <!-- Panel 1: Task Board (Kanban) -->
    <div class="dpd__panel dpd__panel--tasks">
      <div class="dpd__panel-header">
        <span class="dpd__panel-title">Task Board</span>
      </div>
      <div class="dpd__kanban">

        <!-- TODO column -->
        <div class="dpd__col">
          <div class="dpd__col-label">TODO</div>
          <div class="dpd__card">
            <span class="dpd__card-agent" style="color:#fb923c">🔍</span>
            <span class="dpd__card-text">Write unit tests</span>
          </div>
        </div>

        <!-- IN PROGRESS column -->
        <div class="dpd__col">
          <div class="dpd__col-label dpd__col-label--active">IN PROGRESS</div>
          <div class="dpd__card dpd__card--active">
            <span class="dpd__card-agent" style="color:#60a5fa">💻</span>
            <span class="dpd__card-text">Implement dark mode</span>
            <span class="dpd__card-pulse" aria-hidden="true"></span>
          </div>
        </div>

        <!-- IN REVIEW column -->
        <div class="dpd__col">
          <div class="dpd__col-label">IN REVIEW</div>
          <div class="dpd__card">
            <span class="dpd__card-agent" style="color:#34d399">⚙️</span>
            <span class="dpd__card-text">API endpoint</span>
          </div>
        </div>

        <!-- DONE column -->
        <div class="dpd__col">
          <div class="dpd__col-label dpd__col-label--done">DONE</div>
          <div class="dpd__card dpd__card--done">
            <span class="dpd__card-agent" style="color:#f472b6">🎨</span>
            <span class="dpd__card-text">Design system setup</span>
          </div>
        </div>

      </div>
    </div>

    <!-- Panel 2: Message Feed -->
    <div class="dpd__panel dpd__panel--messages">
      <div class="dpd__panel-header">
        <span class="dpd__panel-title">Messages</span>
      </div>
      <div class="dpd__messages">

        <div class="dpd__msg">
          <span class="dpd__msg-avatar" style="background:rgba(167,139,250,0.15);color:#a78bfa">📋</span>
          <div class="dpd__msg-body">
            <span class="dpd__msg-name" style="color:#a78bfa">pm</span>
            <span class="dpd__msg-time">2m ago</span>
            <p class="dpd__msg-text">Starting sprint — implement dark mode toggle</p>
          </div>
        </div>

        <div class="dpd__msg">
          <span class="dpd__msg-avatar" style="background:rgba(96,165,250,0.15);color:#60a5fa">💻</span>
          <div class="dpd__msg-body">
            <span class="dpd__msg-name" style="color:#60a5fa">fe</span>
            <span class="dpd__msg-arrow" aria-hidden="true">→</span>
            <span class="dpd__msg-name" style="color:#34d399">be</span>
            <span class="dpd__msg-time">1m ago</span>
            <p class="dpd__msg-text">Is the color API ready?</p>
          </div>
        </div>

        <div class="dpd__msg">
          <span class="dpd__msg-avatar" style="background:rgba(52,211,153,0.15);color:#34d399">⚙️</span>
          <div class="dpd__msg-body">
            <span class="dpd__msg-name" style="color:#34d399">be</span>
            <span class="dpd__msg-time">45s ago</span>
            <p class="dpd__msg-text">API deployed ✓ Color tokens ready</p>
          </div>
        </div>

        <div class="dpd__msg">
          <span class="dpd__msg-avatar" style="background:rgba(244,114,182,0.15);color:#f472b6">🎨</span>
          <div class="dpd__msg-body">
            <span class="dpd__msg-name" style="color:#f472b6">designer</span>
            <span class="dpd__msg-time">30s ago</span>
            <p class="dpd__msg-text">Light palette finalized — 12 tokens covered</p>
          </div>
        </div>

        <div class="dpd__msg dpd__msg--new">
          <span class="dpd__msg-avatar" style="background:rgba(96,165,250,0.15);color:#60a5fa">💻</span>
          <div class="dpd__msg-body">
            <span class="dpd__msg-name" style="color:#60a5fa">fe</span>
            <span class="dpd__msg-time">just now</span>
            <p class="dpd__msg-text">Toggle wired ✓ Requesting review</p>
          </div>
        </div>

      </div>
    </div>

    <!-- Panel 3: Agent Thoughts -->
    <div class="dpd__panel dpd__panel--thoughts">
      <div class="dpd__panel-header">
        <span class="dpd__panel-title">
          <span style="color:#60a5fa">💻 fe</span>
          &mdash; Agent Thoughts
        </span>
        <span class="dpd__thinking-dot" aria-hidden="true"></span>
      </div>
      <div class="dpd__thoughts">
        <p class="dpd__thoughts-text">
          <span class="dpd__thinking-label">[thinking]</span> CSS vars already set up — hooking into <code class="dpd__inline-code">var(--color-bg-surface)</code> and toggling <code class="dpd__inline-code">:root[data-theme]</code><span class="dpd__cursor" aria-hidden="true">|</span>
        </p>
      </div>
    </div>

  </div>
</div>

<style>
  /* ─── Browser chrome ─── */
  .dpd__browser {
    margin: 2rem 0;
    border-radius: 0.75rem;
    overflow: hidden;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.18);
  }

  .dpd__browser-bar {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.6rem 1rem;
    background-color: var(--sl-color-bg-nav, #1a1b26);
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }

  .dpd__browser-dots {
    display: flex;
    gap: 0.375rem;
    flex-shrink: 0;
  }

  .dpd__dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    opacity: 0.85;
    display: inline-block;
  }

  .dpd__browser-tab {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.25rem 0.75rem;
    background-color: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 0.375rem;
    font-family: var(--sl-font-mono, monospace);
    font-size: 0.6875rem;
    color: rgba(255,255,255,0.5);
    flex-shrink: 0;
  }

  .dpd__tab-icon {
    font-size: 0.625rem;
  }

  .dpd__browser-url {
    flex: 1;
    padding: 0.25rem 0.75rem;
    background-color: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 0.375rem;
    font-family: var(--sl-font-mono, monospace);
    font-size: 0.6875rem;
    color: rgba(255,255,255,0.35);
    display: flex;
    align-items: center;
    gap: 0.5rem;
    min-width: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .dpd__url-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #27C93F;
    flex-shrink: 0;
    opacity: 0.8;
  }

  /* ─── Dashboard panels ─── */
  .dpd__panels {
    display: grid;
    grid-template-columns: 1.8fr 1.6fr 1.4fr;
    background-color: #0f1117;
    min-height: 280px;
  }

  .dpd__panel {
    display: flex;
    flex-direction: column;
    border-right: 1px solid rgba(255,255,255,0.07);
  }

  .dpd__panel:last-child {
    border-right: none;
  }

  .dpd__panel-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.625rem 0.875rem;
    border-bottom: 1px solid rgba(255,255,255,0.07);
    background-color: rgba(255,255,255,0.02);
  }

  .dpd__panel-title {
    font-family: var(--sl-font-mono, monospace);
    font-size: 0.6875rem;
    color: rgba(255,255,255,0.35);
    letter-spacing: 0.04em;
    font-weight: 500;
    text-transform: uppercase;
  }

  /* ─── Kanban ─── */
  .dpd__kanban {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    padding: 0.75rem;
    gap: 0.5rem;
    flex: 1;
  }

  .dpd__col {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .dpd__col-label {
    font-family: var(--sl-font-mono, monospace);
    font-size: 0.5625rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.3);
    font-weight: 500;
    padding: 0 0.125rem;
  }

  .dpd__col-label--active {
    color: #60a5fa;
  }

  .dpd__col-label--done {
    color: #34d399;
  }

  .dpd__card {
    position: relative;
    background-color: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 0.375rem;
    padding: 0.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    overflow: hidden;
  }

  .dpd__card-agent {
    font-size: 0.6875rem;
  }

  .dpd__card-text {
    font-size: 0.625rem;
    color: rgba(255,255,255,0.5);
    line-height: 1.4;
  }

  @keyframes dpd-card-pulse {
    0%, 100% { border-color: rgba(96, 165, 250, 0.4); box-shadow: 0 0 0 0 rgba(96, 165, 250, 0); }
    50%       { border-color: rgba(96, 165, 250, 0.8); box-shadow: 0 0 8px rgba(96, 165, 250, 0.2); }
  }

  .dpd__card--active {
    border-color: rgba(96, 165, 250, 0.4);
    animation: dpd-card-pulse 2.5s ease-in-out infinite;
  }

  .dpd__card-pulse {
    position: absolute;
    top: 0.375rem;
    right: 0.375rem;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #60a5fa;
    animation: dpd-pulse-dot 2s ease-in-out infinite;
  }

  @keyframes dpd-pulse-dot {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%       { opacity: 0.3; transform: scale(0.7); }
  }

  .dpd__card--done {
    opacity: 0.58;
    filter: grayscale(25%);
  }

  /* ─── Messages ─── */
  .dpd__messages {
    display: flex;
    flex-direction: column;
    padding: 0.625rem;
    flex: 1;
    overflow: auto;
  }

  .dpd__msg {
    display: flex;
    gap: 0.5rem;
    padding: 0.5rem 0.375rem;
    border-radius: 0.375rem;
    align-items: flex-start;
  }

  .dpd__msg-avatar {
    width: 26px;
    height: 26px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    flex-shrink: 0;
    line-height: 1;
  }

  .dpd__msg-body {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.25rem;
    flex: 1;
    min-width: 0;
  }

  .dpd__msg-name {
    font-family: var(--sl-font-mono, monospace);
    font-size: 0.6875rem;
    font-weight: 600;
  }

  .dpd__msg-arrow {
    font-size: 0.625rem;
    color: rgba(255,255,255,0.25);
  }

  .dpd__msg-time {
    font-family: var(--sl-font-mono, monospace);
    font-size: 0.5625rem;
    color: rgba(255,255,255,0.25);
    margin-left: 0.25rem;
  }

  .dpd__msg-text {
    width: 100%;
    font-size: 0.6875rem;
    color: rgba(255,255,255,0.5);
    line-height: 1.55;
    margin: 0;
  }

  @keyframes dpd-msg-in {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .dpd__msg--new {
    animation: dpd-msg-in 0.5s ease-out both;
    animation-delay: 0.3s;
    opacity: 0;
  }

  /* ─── Agent Thoughts ─── */
  .dpd__thinking-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background-color: #60a5fa;
    animation: dpd-pulse-dot 1.5s ease-in-out infinite;
    flex-shrink: 0;
  }

  .dpd__thoughts {
    padding: 0.875rem;
    flex: 1;
    display: flex;
    align-items: flex-start;
  }

  .dpd__thoughts-text {
    font-family: var(--sl-font-mono, monospace);
    font-size: 0.6875rem;
    color: rgba(255,255,255,0.5);
    line-height: 1.8;
    margin: 0;
    word-break: break-word;
  }

  .dpd__thinking-label {
    font-family: var(--sl-font-mono, monospace);
    font-size: 0.625rem;
    color: rgba(96, 165, 250, 0.6);
    margin-right: 0.25rem;
  }

  .dpd__inline-code {
    font-family: var(--sl-font-mono, monospace);
    font-size: 0.6875rem;
    color: #60a5fa;
    background-color: rgba(96, 165, 250, 0.12);
    padding: 0.05em 0.3em;
    border-radius: 0.2em;
  }

  @keyframes dpd-blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0; }
  }

  .dpd__cursor {
    display: inline-block;
    color: #60a5fa;
    font-weight: 400;
    animation: dpd-blink 1s step-end infinite;
    margin-left: 1px;
  }

  /* ─── Responsive ─── */
  @media (max-width: 800px) {
    .dpd__panels {
      grid-template-columns: 1fr 1fr;
    }

    .dpd__panel--tasks {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 520px) {
    .dpd__panels {
      grid-template-columns: 1fr;
    }

    .dpd__panel--tasks {
      grid-column: 1;
    }

    .dpd__browser-tab {
      display: none;
    }

    .dpd__kanban {
      grid-template-columns: repeat(2, 1fr);
    }

    .dpd__col-label {
      font-size: 0.5rem;
    }
  }
</style>
