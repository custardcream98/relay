---
import { type Lang, useTranslations } from "../../i18n/landing";

// biome-ignore lint/correctness/noUnusedVariables: used in Astro template
const base = import.meta.env.BASE_URL;
const { lang = "en" }: { lang?: Lang } = Astro.props;
const t = useTranslations(lang);

// biome-ignore lint/correctness/noUnusedVariables: used in Astro template
const docsSlug =
  lang === "ko-KR" ? "ko-KR/getting-started/installation" : "getting-started/installation";

// biome-ignore lint/correctness/noUnusedVariables: used in Astro template
const snippets = [
  {
    step: "01",
    label: t("qs.step1.label"),
    code: `claude mcp add --scope user relay -- npx -y --package @custardcream/relay relay`,
    comment: t("qs.step1.comment"),
  },
  {
    step: "02",
    label: t("qs.step2.label"),
    code: `/relay:init`,
    comment: t("qs.step2.comment"),
  },
  {
    step: "03",
    label: t("qs.step3.label"),
    code: `/relay:relay "add OAuth login with Google"`,
    comment: t("qs.step3.comment"),
  },
];
---

<section class="qs">
  <div class="qs__inner">
    <!-- Left: title + link -->
    <div class="qs__copy">
      <span class="qs__label" aria-hidden="true">{t("qs.label")}</span>
      <h2 class="qs__title">{t("qs.title1")}<br />{t("qs.title2")}</h2>
      <p class="qs__desc">
        {t("qs.desc")}
      </p>
      <a href={`${base}/${docsSlug}`} class="qs__link">
        {t("qs.link")}
        <span aria-hidden="true">→</span>
      </a>
    </div>

    <!-- Right: terminal snippet stack -->
    <div class="qs__snippets" role="list" aria-label="Quick start steps">
      {
        snippets.map((s, i) => (
          <div class="qs__block" role="listitem" style={`animation-delay: ${i * 0.12}s`}>
            <div class="qs__block-header">
              <span class="qs__block-step">{s.step}</span>
              <span class="qs__block-title">{s.label}</span>
            </div>
            <div class="qs__block-terminal">
              <span class="qs__prompt" aria-hidden="true">$</span>
              <div class="qs__code-wrap">
                <code class="qs__code">{s.code}</code>
                <span class="qs__comment" aria-hidden="true">{s.comment}</span>
              </div>
            </div>
          </div>
        ))
      }
      <!-- prerequisite note -->
      <p class="qs__note">{t("qs.prereqNote")}</p>
    </div>
  </div>
</section>

<style>
  .qs {
    border-top: 1px solid var(--color-border);
    background-color: var(--color-bg-surface);
    padding: 5.5rem 0;
  }

  .qs__inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 clamp(1.25rem, 5vw, 2.5rem);
    display: grid;
    grid-template-columns: 1fr 1.25fr;
    gap: 5rem;
    align-items: center;
  }

  /* Left copy */
  .qs__copy {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .qs__label {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-accent);
    letter-spacing: 0.06em;
    font-weight: 500;
  }

  .qs__title {
    font-family: var(--font-display);
    font-size: clamp(1.875rem, 3.5vw, 2.625rem);
    font-weight: 400;
    color: var(--color-text-primary);
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin: 0;
  }

  .qs__desc {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.75;
    margin: 0;
    font-weight: 300;
  }

  .qs__link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--color-accent);
    text-decoration: none;
    letter-spacing: 0.02em;
    transition: gap 0.18s;
  }

  .qs__link:hover {
    gap: 0.625rem;
  }

  /* Right snippet stack */
  .qs__snippets {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
  }

  @keyframes block-in {
    from { opacity: 0; transform: translateX(10px); }
    to   { opacity: 1; transform: translateX(0); }
  }

  .qs__block {
    border: 1px solid var(--color-border-strong);
    border-radius: 0.5rem;
    overflow: hidden;
    background-color: var(--color-bg-raised);
    animation: block-in 0.35s ease-out both;
    transition: border-color 0.18s, box-shadow 0.18s;
  }

  .qs__block:hover {
    border-color: var(--color-accent);
    box-shadow: 0 0 0 1px var(--color-accent-glow);
  }

  .qs__block-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.5625rem 0.875rem;
    border-bottom: 1px solid var(--color-border);
    background-color: var(--color-bg-surface);
  }

  .qs__block-step {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    font-weight: 500;
    color: var(--color-accent);
    letter-spacing: 0.1em;
    opacity: 0.7;
  }

  .qs__block-title {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--color-text-primary);
    opacity: 0.6;
    letter-spacing: 0.03em;
  }

  .qs__block-terminal {
    display: flex;
    align-items: flex-start;
    gap: 0.625rem;
    padding: 0.875rem 0.875rem 0.875rem;
  }

  .qs__prompt {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--color-accent);
    font-weight: 500;
    user-select: none;
    padding-top: 0.0625rem;
  }

  .qs__code-wrap {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .qs__code {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--color-text-primary);
    letter-spacing: 0.01em;
    word-break: break-all;
  }

  .qs__comment {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--color-text-primary);
    opacity: 0.55;
    letter-spacing: 0.02em;
  }

  /* Prerequisite note */
  .qs__note {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--color-text-secondary);
    opacity: 0.65;
    margin: 0.25rem 0 0;
    padding: 0 0.125rem;
    line-height: 1.6;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .qs__inner {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
  }
</style>
