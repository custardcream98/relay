---
import { type Lang, useTranslations } from "../../i18n/landing";

const { lang = "en" }: { lang?: Lang } = Astro.props;
const t = useTranslations(lang);

const features = [
  {
    index: "A",
    title: t("features.A.title"),
    description: t("features.A.desc"),
    detail: t("features.A.detail"),
  },
  {
    index: "B",
    title: t("features.B.title"),
    description: t("features.B.desc"),
    detail: t("features.B.detail"),
  },
  {
    index: "C",
    title: t("features.C.title"),
    description: t("features.C.desc"),
    detail: t("features.C.detail"),
  },
  {
    index: "D",
    title: t("features.D.title"),
    description: t("features.D.desc"),
    detail: t("features.D.detail"),
  },
];
---

<section class="features">
  <div class="features__header">
    <span class="features__label" aria-hidden="true">{t("features.label")}</span>
    <h2 class="features__title">{t("features.title1")}<br />{t("features.title2")}</h2>
  </div>

  <!-- 2×2 grid — compact editorial cards -->
  <div class="features__grid">
    {
      features.map((f, i) => (
        <div class="features__cell" style={`animation-delay: ${i * 0.08}s`}>
          <div class="features__cell-index" aria-hidden="true">{f.index}</div>
          <div class="features__cell-body">
            <h3 class="features__cell-title">{f.title}</h3>
            <p class="features__cell-desc">{f.description}</p>
            <p class="features__cell-detail">{f.detail}</p>
          </div>
        </div>
      ))
    }
  </div>
</section>

<style>
  .features {
    border-top: 1px solid var(--color-border);
    background-color: var(--color-bg-root);
  }

  .features__header {
    max-width: 1100px;
    margin: 0 auto;
    padding: 5rem clamp(1.25rem, 5vw, 2.5rem) 3.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .features__label {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-accent);
    letter-spacing: 0.06em;
    font-weight: 500;
  }

  .features__title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4.5vw, 3rem);
    font-weight: 400;
    color: var(--color-text-primary);
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin: 0;
  }

  /* 2×2 grid */
  .features__grid {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 clamp(1.25rem, 5vw, 2.5rem) 5rem;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    background-color: var(--color-border);
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    overflow: hidden;
  }

  @keyframes cell-in {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  .features__cell {
    display: flex;
    gap: 1.25rem;
    padding: 2rem 1.75rem;
    background-color: var(--color-bg-root);
    transition: background-color 0.18s;
    animation: cell-in 0.4s ease-out both;
  }

  .features__cell:hover {
    background-color: var(--color-bg-raised);
  }

  /* Alphabetic index */
  .features__cell-index {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.25rem;
    font-weight: 400;
    color: var(--color-accent);
    opacity: 0.5;
    flex-shrink: 0;
    line-height: 1.4;
    transition: opacity 0.18s;
  }

  .features__cell:hover .features__cell-index {
    opacity: 1;
  }

  .features__cell-body {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .features__cell-title {
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 500;
    color: var(--color-text-primary);
    margin: 0;
    letter-spacing: -0.01em;
  }

  .features__cell-desc {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    line-height: 1.65;
    margin: 0;
    font-weight: 300;
  }

  .features__cell-detail {
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    font-weight: 400;
    color: var(--color-accent);
    margin: 0.25rem 0 0;
  }

  /* Responsive */
  @media (max-width: 640px) {
    .features__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
