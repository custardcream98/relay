---
// biome-ignore lint/correctness/noUnusedVariables: Astro 템플릿에서 사용
const steps = [
  {
    number: "01",
    title: "Install",
    description:
      "Add the relay MCP server to Claude Code with one command. Optionally customise agent personas in agents.yml.",
    code: "claude mcp add --npm @custardcream/relay relay-server",
  },
  {
    number: "02",
    title: "Init",
    description:
      "Run /relay:init once. All agents scan the codebase in parallel and write shared memory to .relay/memory/.",
    code: "/relay:init",
  },
  {
    number: "03",
    title: "Ship",
    description:
      "Describe the feature. PM breaks it down, agents execute it, QA verifies, Deployer ships.",
    code: '/relay:relay "add dark mode toggle"',
  },
];
---

<section class="how">
  <!-- 섹션 헤더 -->
  <div class="how__header">
    <div class="how__header-inner">
      <span class="how__label" aria-hidden="true">// how it works</span>
      <h2 class="how__title">Three commands.<br />Zero to shipped.</h2>
      <p class="how__subtitle">
        No orchestrator. No extra billing. Just Claude Code's built-in Agent tool.
      </p>
    </div>
  </div>

  <!-- 스텝 목록 — 수평 룰 구분 editorial 레이아웃 -->
  <div class="how__steps">
    {
      steps.map((step, i) => (
        <div class="how__step" style={`animation-delay: ${i * 0.1}s`}>
          <div class="how__step-num-col" aria-hidden="true">
            <span class="how__step-num">{step.number}</span>
          </div>
          <div class="how__step-content">
            <h3 class="how__step-title">{step.title}</h3>
            <p class="how__step-desc">{step.description}</p>
          </div>
          <div class="how__step-code-col">
            <code class="how__step-code">{step.code}</code>
          </div>
        </div>
      ))
    }
  </div>
</section>

<style>
  .how {
    border-top: 1px solid var(--color-border);
  }

  /* 헤더 영역 */
  .how__header {
    background-color: var(--color-bg-surface);
    padding: 5rem 0 4.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  .how__header-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 clamp(1.25rem, 5vw, 2.5rem);
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .how__label {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-accent);
    letter-spacing: 0.06em;
    font-weight: 500;
  }

  .how__title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4.5vw, 3rem);
    font-weight: 400;
    color: var(--color-text-primary);
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin: 0;
    max-width: 560px;
  }

  .how__subtitle {
    font-size: 1rem;
    color: var(--color-text-secondary);
    line-height: 1.7;
    max-width: 480px;
    margin: 0;
    font-weight: 300;
  }

  /* 스텝 리스트 — editorial 가로 레이아웃 */
  .how__steps {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 clamp(1.25rem, 5vw, 2.5rem);
    overflow: hidden;
  }

  @keyframes step-in {
    from { opacity: 0; transform: translateY(12px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .how__step {
    display: grid;
    grid-template-columns: 4rem 1fr auto;
    align-items: center;
    gap: 2rem;
    padding: 2.25rem 0.75rem;
    border-bottom: 1px solid var(--color-border);
    animation: step-in 0.4s ease-out both;
    border-radius: 0.5rem;
    transition: background-color 0.18s, border-bottom-color 0.18s;
  }

  .how__step:last-child {
    border-bottom: none;
  }

  .how__step:hover {
    background-color: var(--color-accent-glow);
    border-bottom-color: transparent;
  }

  .how__step:hover + .how__step {
    border-top-color: transparent;
  }

  /* 번호 컬럼 */
  .how__step-num-col {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .how__step-num {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-accent);
    letter-spacing: 0.1em;
    opacity: 0.8;
  }

  /* 내용 컬럼 */
  .how__step-content {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .how__step-title {
    font-family: var(--font-display);
    font-size: 1.375rem;
    font-weight: 400;
    color: var(--color-text-primary);
    letter-spacing: -0.02em;
    margin: 0;
  }

  .how__step-desc {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.65;
    margin: 0;
    font-weight: 300;
    max-width: 440px;
  }

  /* 코드 컬럼 */
  .how__step-code-col {
    flex-shrink: 0;
    max-width: 320px;
  }

  .how__step-code {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
    background-color: var(--color-bg-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.375rem;
    padding: 0.5rem 0.875rem;
    word-break: break-all;
    line-height: 1.6;
    transition: border-color 0.18s, color 0.18s;
  }

  .how__step:hover .how__step-code {
    border-color: var(--color-accent);
    color: var(--color-text-primary);
  }

  /* 반응형 */
  @media (max-width: 700px) {
    .how__step {
      grid-template-columns: 2.5rem 1fr;
      grid-template-rows: auto auto;
    }

    .how__step-code-col {
      grid-column: 2;
      max-width: 100%;
    }
  }
</style>
