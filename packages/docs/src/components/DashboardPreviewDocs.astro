---
// Standalone dashboard preview for MDX docs pages.
// Uses the actual dashboard screenshot so the preview always matches the real UI.
interface Props {
  lang?: string;
}
const { lang } = Astro.props;
---

<div class="dpd__wrapper">
  <img
    src={lang === "ko-KR" ? "/relay/screenshots/dashboard-ko.png" : "/relay/screenshots/dashboard-en.png"}
    alt="relay dashboard — live session in progress"
    class="dpd__screenshot"
    width="1400"
    height="875"
    loading="lazy"
  />
</div>

<style>
  .dpd__wrapper {
    margin: 2rem 0;
    border-radius: 0.75rem;
    overflow: hidden;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.35);
    border: 1px solid rgba(255, 255, 255, 0.08);
  }

  .dpd__screenshot {
    display: block;
    width: 100%;
    height: auto;
  }
</style>
