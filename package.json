{
  "name": "relay",
  "version": "0.1.0",
  "description": "Multi-agent collaboration framework built on Claude Code",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/custardcream98/relay.git"
  },
  "homepage": "https://custardcream98.github.io/relay",
  "license": "MIT",
  "scripts": {
    "dev": "bun run --filter @relay/server dev",
    "start": "bun run --filter @relay/server start",
    "test": "bun run --filter @relay/server test",
    "check": "biome check .",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "dashboard:dev": "bun run --filter @relay/dashboard dev",
    "dashboard:build": "bun run --filter @relay/dashboard build",
    "docs:dev": "bun run --filter @relay/docs dev",
    "docs:build": "bun run --filter @relay/docs build",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "husky": "^9.1.7"
  }
}
