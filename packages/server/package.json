{
  "name": "@custardcream/relay",
  "version": "0.0.2",
  "description": "MCP server for the relay multi-agent framework",
  "type": "module",
  "bin": {
    "relay-server": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "RELAY_DASHBOARD_DIR=$(pwd)/../dashboard/dist bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "build": "bun run build.ts",
    "test": "bun test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "hono": "^4.12.7",
    "js-yaml": "^4.1.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "1.3.10",
    "@types/js-yaml": "^4.0.9"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/custardcream98/relay.git",
    "directory": "packages/server"
  },
  "license": "MIT"
}
